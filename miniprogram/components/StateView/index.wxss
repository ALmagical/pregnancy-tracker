.wrap {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.subtle {
  font-size: 26rpx;
  color: #6b7280;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  padding: 16rpx 22rpx;
  background: rgba(42, 125, 225, 0.1);
  color: #2a7de1;
  border-radius: 16rpx;
  font-size: 26rpx;
}

