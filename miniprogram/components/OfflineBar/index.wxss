.bar {
  position: sticky;
  top: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 18rpx;
  background: rgba(255, 245, 235, 0.98);
  color: #9a3412;
  border-bottom: 1rpx solid rgba(234, 88, 12, 0.18);
}

.text {
  font-size: 24rpx;
}

.pill {
  margin-left: 16rpx;
  padding: 6rpx 12rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
  background: rgba(234, 88, 12, 0.12);
}

