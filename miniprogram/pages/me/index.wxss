.page {
}

.hero {
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #eef2ff 0%, #ffffff 70%);
}

.heroTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.heroSubtle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.infoCard {
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.rowMain {
  flex: 1;
}

.rowIcon {
  width: 34rpx;
  height: 34rpx;
  margin-bottom: 6rpx;
}

.rowTitle {
  font-size: 30rpx;
  font-weight: 600;
}

.link {
  font-size: 26rpx;
  color: #2a7de1;
  padding: 8rpx 10rpx;
}

.linkPill {
  border-radius: 999rpx;
  background: #eff6ff;
  padding: 10rpx 20rpx;
}

