.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.left {
  flex: 1;
  padding-right: 20rpx;
}

.rowTitle {
  font-size: 30rpx;
  font-weight: 600;
}

.mark {
  font-size: 24rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
}

.mark.on {
  background: rgba(34, 197, 94, 0.12);
  color: #16a34a;
}

.btnRow {
  display: flex;
  gap: 14rpx;
}

.btnPrimary {
  flex: 1;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: #2a7de1;
  color: #ffffff;
  font-size: 28rpx;
  text-align: center;
}

.btnGhost {
  flex: 1;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: rgba(42, 125, 225, 0.1);
  color: #2a7de1;
  font-size: 28rpx;
  text-align: center;
}

.hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9a3412;
}

