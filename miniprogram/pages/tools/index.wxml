<offline-bar online="{{online}}" queueSize="{{offlineQueueSize}}" />

<view class="page">
  <view class="hero card">
    <view class="heroTitle">常用工具</view>
    <view class="heroSubtle">快速进入记录与计时功能</view>
  </view>

  <view class="grid">
    <view class="item card" wx:for="{{tools}}" wx:key="key" data-action="{{item.action}}" bindtap="onToolTap">
      <image class="itemIcon" src="{{item.icon}}" mode="aspectFit" />
      <view class="itemTitle">{{item.title}}</view>
      <view class="itemSub">{{item.sub}}</view>
    </view>
  </view>
</view>

