<offline-bar online="{{online}}" queueSize="{{offlineQueueSize}}" />

<view class="page">
  <view class="title">胎动计数</view>
  <view class="card">
    <view class="subtle">当前计数</view>
    <view class="counter">{{active?active.count:0}}</view>
    <view class="rowBtns">
      <view class="btnGhost" bindtap="onStart" wx:if="{{!active}}">开始</view>
      <view class="btnGhost" bindtap="onMinus" wx:if="{{active}}">撤销</view>
      <view class="btnPrimary" bindtap="onPlus" wx:if="{{active}}">+1</view>
      <view class="btnDanger" bindtap="onFinish" wx:if="{{active}}">结束并保存</view>
    </view>
    <view wx:if="{{!online}}" class="hint">离线保存会先暂存，联网后自动同步</view>
  </view>

  <view class="card" style="margin-top: 16rpx;">
    <view class="subtle" style="margin-bottom: 10rpx;">历史记录</view>
    <view wx:if="{{sessions.length===0}}" class="subtle">暂无记录</view>
    <view wx:for="{{sessions}}" wx:key="id" class="histRow">
      <view>
        <view class="histTitle">{{item.count}} 次</view>
        <view class="subtle">{{item.startedAt}}</view>
      </view>
      <view class="subtle">{{item.durationSec}}s</view>
    </view>
  </view>
</view>

