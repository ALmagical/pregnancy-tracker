<offline-bar online="{{online}}" queueSize="{{offlineQueueSize}}" />

<view class="page">
  <view class="title">设置孕期信息</view>
  <view class="subtle">用于计算孕周与首页展示</view>

  <view class="card" style="margin-top: 16rpx;">
    <view class="field">
      <view class="label">状态</view>
      <picker mode="selector" range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="onStatusChange">
        <view class="picker">{{statusOptions[statusIndex].label}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">末次月经（必填）</view>
      <picker mode="date" value="{{lastPeriodDate}}" bindchange="onDateChange">
        <view class="picker">{{lastPeriodDate||'请选择日期'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">身高（选填）</view>
      <input class="input" type="number" placeholder="例如 160（cm）" value="{{heightCm}}" bindinput="onHeightInput" />
    </view>

    <view class="field">
      <view class="label">孕前体重（选填）</view>
      <input class="input" type="digit" placeholder="例如 55.0（kg）" value="{{prePregnancyWeight}}" bindinput="onPreWeightInput" />
    </view>

    <view class="btnPrimary" bindtap="onSave">保存</view>
  </view>
</view>

