<offline-bar online="{{online}}" queueSize="{{offlineQueueSize}}" />

<view class="page">
  <view class="title">Today</view>

  <state-view wx:if="{{state!=='normal'}}" state="{{state}}" emptyText="还没有设置孕期信息" emptyActionText="开始设置孕期信息" bind:action="goProfile" />

  <view wx:else>
    <view class="card">
      <view class="subtle">当前孕周</view>
      <view class="big">第 {{userInfo.currentWeek}} 周 + {{userInfo.currentDay}} 天</view>
      <view class="subtle" style="margin-top: 8rpx;">距离预产期还有 {{daysToDue}} 天</view>
    </view>

    <view class="card" style="margin-top: 16rpx;">
      <view class="row">
        <view>
          <view class="rowTitle">下次产检</view>
          <view class="subtle">{{nextCheckupText}}</view>
        </view>
        <view class="link" bindtap="goCheckup">查看</view>
      </view>
    </view>

    <view class="card" style="margin-top: 16rpx;">
      <view class="rowTitle" style="margin-bottom: 10rpx;">快捷工具</view>
      <view class="grid">
        <view class="tool" data-tool="weight" bindtap="onQuickTool">体重</view>
        <view class="tool" data-tool="fm" bindtap="onQuickTool">胎动</view>
        <view class="tool" data-tool="contraction" bindtap="onQuickTool">宫缩</view>
        <view class="tool" data-tool="checklist" bindtap="onQuickTool">待产清单</view>
      </view>
    </view>
  </view>
</view>

