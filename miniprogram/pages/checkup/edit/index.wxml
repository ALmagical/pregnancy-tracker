<offline-bar online="{{online}}" queueSize="{{offlineQueueSize}}" />

<view class="page">
  <view class="title">{{id?'编辑产检':'新增产检'}}</view>

  <view class="card">
    <view class="field">
      <view class="label">产检日期（必填）</view>
      <picker mode="date" value="{{checkupDate}}" bindchange="onDateChange">
        <view class="picker">{{checkupDate||'请选择日期'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">产检类型（必填）</view>
      <input class="input" placeholder="例如 大排畸" value="{{checkupType}}" bindinput="onTypeInput" />
    </view>

    <view class="field">
      <view class="label">医院（选填）</view>
      <input class="input" placeholder="例如 XX市妇幼保健院" value="{{hospital}}" bindinput="onHospitalInput" />
    </view>

    <view class="field">
      <view class="label">备注（选填）</view>
      <textarea class="textarea" placeholder="仅保存在本地，不会用于埋点上报" value="{{note}}" bindinput="onNoteInput" maxlength="200" />
    </view>

    <view class="btnPrimary" bindtap="onSave">保存</view>
  </view>
</view>

